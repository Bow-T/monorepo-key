<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- KHÔNG bật app-sandbox: app cài đặt cần ghi
	     ~/Library/Application Support/BowKey/settings.json để bộ gõ Swift
	     (cũng không sandbox) đọc cùng file. App nội bộ, không qua App Store. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
</dict>
</plist>
